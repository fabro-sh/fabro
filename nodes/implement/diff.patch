+                serde_json::json!("freeform"),
+            );
+            outcome.context_updates.insert(
+                keys::HUMAN_GATE_LABEL.to_string(),
+                serde_json::json!("[Simulated] auto-selected"),
+            );
+            Ok(outcome)
+        } else {
+            Ok(Outcome::simulated(&node.id))
+        }
+    }
