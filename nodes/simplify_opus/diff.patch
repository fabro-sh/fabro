+pub fn spawn_fabro_subcommand(subcommand: &str, filename: &str, json: &[u8]) {
+    let tmp_dir = match dirs::home_dir() {
+        Some(h) => h.join(".fabro").join("tmp"),
+        None => return,
+    };
+    if std::fs::create_dir_all(&tmp_dir).is_err() {
