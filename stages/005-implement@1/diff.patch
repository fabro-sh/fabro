+        fabro_agent::Error::Llm(err) => AgentApiErrorDisposition::Terminal(Error::Llm(err)),
+        other => AgentApiErrorDisposition::Terminal(Error::handler(format!(
+            "Agent session failed: {other}"
+        ))),
+    }
